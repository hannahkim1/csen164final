<% content_for :title, "Checkout" %>

<h1 id="catalog-heading">Checkout</h1>

<p class="order-total">Order total: <%= @cart.total_price %></p>

<% if @order.errors.any? %>
  <div class="form-errors">
    <h3><%= pluralize(@order.errors.count, "error") %> prevented this order from being placed:</h3>
    <ul>
      <% @order.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @order do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name %>
  </div>
  <div>
    <%= form.label :email %><br>
    <%= form.text_field :email %>
  </div>
  <div>
    <%= form.label :pay_type %><br>
    <%= form.select :pay_type, Order::PAYMENT_TYPES, prompt: "Select a payment method" %>
  </div>
  <div>
    <%= form.submit "Place order" %>
  </div>
<% end %>

<div>
  <%= link_to "Back to products", products_path %>
</div>
