<% content_for :title, "Order ##{@order.id}" %>

<h1 id="catalog-heading">Order #<%= @order.id %></h1>

<div class="order-details">
  <p><strong>Name:</strong> <%= @order.name %></p>
  <p><strong>Email:</strong> <%= @order.email %></p>
  <p><strong>Payment:</strong> <%= @order.pay_type %></p>
  <p><strong>Placed:</strong> <%= @order.created_at.strftime("%B %-d, %Y") %></p>
</div>

<table class="order-items">
  <thead>
    <tr><th>Product</th><th>Quantity</th><th>Price</th><th>Subtotal</th></tr>
  </thead>
  <tbody>
    <% @order.cartitems.each do |item| %>
      <tr>
        <td><%= item.product.name %></td>
        <td><%= item.quantity %></td>
        <td><%= item.product.price %></td>
        <td><%= item.item_total_price %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr><th colspan="3">Total</th><th><%= @order.total_price %></th></tr>
  </tfoot>
</table>

<div>
  <%= link_to "My orders", orders_path %> |
  <%= link_to "Continue shopping", products_path %>
</div>
